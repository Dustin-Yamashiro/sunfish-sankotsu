DEV_THEME_PATH=/home/example/public_html/wp-content/themes/theme/
DEV_BLOCK_PLUGIN_PATH=/home/example/public_html/wp-content/plugins/original-blocks/

PRD_SSH_HOST=example-prod
PRD_THEME_PATH=/home/example/public_html/wp-content/themes/theme/
PRD_BLOCK_PLUGIN_PATH=/home/example/public_html/wp-content/plugins/original-blocks/
